# JT-Hub Nginx Dockerfile — 多阶段构建
# 从项目根目录构建: docker build -f Dockerfile.nginx -t jthub-nginx .
# 包含：用户端静态文件 + 管理端静态文件 + Nginx 反向代理配置

# ─── Stage 1: 构建用户端 (Frontend) ─────────────────────────────
FROM node:20-alpine AS build-frontend

RUN corepack enable && corepack prepare pnpm@10 --activate

WORKDIR /app

COPY pnpm-workspace.yaml pnpm-lock.yaml package.json ./
COPY frontend/package.json frontend/

RUN pnpm install --frozen-lockfile --filter jthub-frontend

COPY frontend/ frontend/

RUN pnpm --filter jthub-frontend build

# ─── Stage 2: 构建管理端 (Admin) ────────────────────────────────
FROM node:20-alpine AS build-admin

RUN corepack enable && corepack prepare pnpm@10 --activate

WORKDIR /app

COPY pnpm-workspace.yaml pnpm-lock.yaml package.json ./
COPY admin/package.json admin/

RUN pnpm install --frozen-lockfile --filter admin

COPY admin/ admin/

RUN pnpm --filter admin build

# ─── Stage 3: Nginx 最终镜像 ────────────────────────────────────
FROM nginx:alpine

# 安装 curl（用于健康检查）
RUN apk add --no-cache curl

# 删除默认配置
RUN rm -f /etc/nginx/conf.d/default.conf

# Nginx 配置
COPY deploy/nginx-docker.conf /etc/nginx/conf.d/jthub.conf

# 用户端静态文件
COPY --from=build-frontend /app/frontend/dist/ /usr/share/nginx/html/

# 管理端静态文件（/admin/ 子路径）
COPY --from=build-admin /app/admin/dist/ /usr/share/nginx/html/admin/

EXPOSE 80

HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
  CMD curl -sf http://localhost:80/health || exit 1
