# 环境变量 — 复制为 .env 并填入真实值
# ⚠️  请勿将 .env 提交到 git

# ── 数据库 ──────────────────────────────────────────────────
DATABASE_URL="postgresql://jthub:your_strong_password@localhost:5432/jthub_prod"

# ── JWT ─────────────────────────────────────────────────────
# 生成随机密钥: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-this-to-a-long-random-string-in-production"
JWT_EXPIRES_IN="7d"

# ── Server酱 推送（管理员新订单微信通知）──────────────────
# 申请地址: https://sct.ftqq.com/
SERVERCHAN_TOKEN="SCT_your_serverchan_token"

# ── 管理员账号 ───────────────────────────────────────────────
# 生成哈希: node -e "require('bcrypt').hash('your_password',10).then(console.log)"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD_HASH="$2b$10$placeholder_replace_with_real_bcrypt_hash"

# ── 管理员微信号（展示给用户的联系方式）──────────────────
ADMIN_WECHAT_ID="Jt--04"

# ── 邮件服务（Resend）────────────────────────────────────────
# 申请地址: https://resend.com
# 需要在 Resend 控制台验证域名后才能发送给任意用户
RESEND_API_KEY="re_your_api_key_here"
MAIL_FROM="noreply@jthub.cc.cd"

# ── 应用配置 ─────────────────────────────────────────────────
NODE_ENV="development"
PORT="3000"
APP_BASE_URL="https://jthub.cc.cd"
